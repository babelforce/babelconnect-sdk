  "patternProperties": {
    "^(agent_id)$": {
      "default": "",
      "type": "string"
    },
    "^(application_id)$": {
      "default": "",
      "type": "string"
    },
    "^(call_id)$": {
      "default": "",
      "type": "string"
    }
  },
  "properties": {
    "agentId": {
      "default": "",
      "type": "string"
    },
    "applicationId": {
      "default": "",
      "type": "string"
    },
    "callId": {
      "default": "",
      "type": "string"
    },
    "to": {
      "default": "",
      "type": "string"
    },
    "warm": {
      "default": false,
      "type": "boolean"
    }
  },
  "title": "Transfer",
  "type": "object"
}
