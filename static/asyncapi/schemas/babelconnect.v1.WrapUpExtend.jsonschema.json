{
  "$id": "babelconnect.v1.WrapUpExtend.jsonschema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "WrapUpExtend adds time to the agent's after-call-work countdown.",
  "properties": {
    "seconds": {
      "anyOf": [
        {
          "maximum": 2147483647,
          "minimum": -2147483648,
          "type": "integer"
        },
        {
          "pattern": "^-?[0-9]+$",
          "type": "string"
        }
      ],
      "default": 0
    }
  },
  "title": "Wrap Up Extend",
  "type": "object"
}
